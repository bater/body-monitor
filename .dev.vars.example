# Copy to .dev.vars (gitignored) for local AI testing with `npm run dev`.
# Set ONE key — Mistral wins if both are set.

# Mistral free tier (https://console.mistral.ai → API Keys; needs the free "Experiment" plan enabled)
MISTRAL_API_KEY=
# MISTRAL_MODEL=mistral-small-latest

# OpenRouter (https://openrouter.ai/keys) — any model with vision support
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=google/gemini-2.5-flash

# Local identity (wrangler dev has no Cloudflare Access in front).
# Switch the value to simulate different users.
DEV_USER_EMAIL=bater.chen@frontier.cool
