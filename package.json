{
  "name": "body-monitor",
  "version": "0.0.8",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run build:web && wrangler dev",
    "build:web": "vite build web",
    "deploy": "npm run build:web && wrangler deploy",
    "typecheck": "tsc --noEmit -p . && tsc --noEmit -p web",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply body-monitor-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply body-monitor-db --remote"
  },
  "dependencies": {
    "@block65/webcrypto-web-push": "^1.0.2",
    "hono": "^4.6.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250620.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.0.0"
  }
}
