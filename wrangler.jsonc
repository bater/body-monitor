{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "body-buddy",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  // web-push lib references node:crypto in its fallback path (unused on workerd, but must resolve)
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": "web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    // /welcome is the public landing page rendered by the Worker (bypass it in Access)
    "run_worker_first": ["/api/*", "/welcome"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "body-monitor-db",
      "database_id": "8a86c63c-3224-4fbd-95f2-0e1155e8f47f",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "PHOTOS",
      "bucket_name": "body-monitor-photos"
    }
  ],
  "vars": {
    // Cloudflare Access identity: team domain + this app's Audience tag.
    // Until ACCESS_AUD is filled in, the Worker trusts the email header Access
    // injects at the edge; with it set, the signed JWT is fully verified.
    "ACCESS_TEAM_DOMAIN": "bater-made.cloudflareaccess.com",
    "ACCESS_AUD": "38e649fc5079be2e8cd24382856a40541021b03b00d68ccebf61fdfefc1f1d92",
    // First login among these emails adopts all pre-multi-user data
    "OWNER_EMAILS": "bater.coder@gmail.com",
    // Web Push VAPID public key (public by design; private half is a secret)
    "VAPID_PUBLIC_KEY": "BHoskjdvQb_YlMmpUd84Fp-o-FP0azDpUxYfagw8IlPEbtYjdRSjZx6k1YJIhjuH9d3HLXj2aqFSbaknRbPpEeY",
    "VAPID_SUBJECT": "mailto:bater.coder@gmail.com",
    // Gmail address that sends invite emails (App Password is a secret, see below)
    "GMAIL_USER": "bater.coder@gmail.com"
  },
  "triggers": {
    // Meal reminders in Asia/Taipei: 09:30 / 13:30 / 19:30 → 01:30 / 05:30 / 11:30 UTC
    "crons": ["30 1,5,11 * * *"]
  },
  "observability": {
    "enabled": true
  }
  // Secrets (set via `wrangler secret put`, or .dev.vars locally) — set ONE:
  //   MISTRAL_API_KEY      → uses api.mistral.ai, model MISTRAL_MODEL (default mistral-small-latest)
  //   OPENROUTER_API_KEY   → uses openrouter.ai, model OPENROUTER_MODEL (default google/gemini-2.5-flash)
  // Optional plain vars MISTRAL_MODEL / OPENROUTER_MODEL can go in a "vars" block here.
  //   GMAIL_APP_PASSWORD   → 16-char Gmail App Password (needs 2FA); invite emails
  //                          are a no-op until this is set. GMAIL_USER is above.
}
