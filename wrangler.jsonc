{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "body-monitor",
  "main": "src/index.ts",
  "compatibility_date": "2026-06-01",
  "assets": {
    "directory": "web/dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application",
    "run_worker_first": ["/api/*"]
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "body-monitor-db",
      "database_id": "8a86c63c-3224-4fbd-95f2-0e1155e8f47f",
      "migrations_dir": "migrations"
    }
  ],
  "r2_buckets": [
    {
      "binding": "PHOTOS",
      "bucket_name": "body-monitor-photos"
    }
  ],
  "vars": {
    // Cloudflare Access identity: team domain + this app's Audience tag.
    // Until ACCESS_AUD is filled in, the Worker trusts the email header Access
    // injects at the edge; with it set, the signed JWT is fully verified.
    "ACCESS_TEAM_DOMAIN": "rough-sea-d78c.cloudflareaccess.com",
    "ACCESS_AUD": "38e649fc5079be2e8cd24382856a40541021b03b00d68ccebf61fdfefc1f1d92",
    // First login among these emails adopts all pre-multi-user data
    "OWNER_EMAILS": "bater.chen@frontier.cool,baterme@gmail.com"
  },
  "observability": {
    "enabled": true
  }
  // Secrets (set via `wrangler secret put`, or .dev.vars locally) — set ONE:
  //   MISTRAL_API_KEY      → uses api.mistral.ai, model MISTRAL_MODEL (default mistral-small-latest)
  //   OPENROUTER_API_KEY   → uses openrouter.ai, model OPENROUTER_MODEL (default google/gemini-2.5-flash)
  // Optional plain vars MISTRAL_MODEL / OPENROUTER_MODEL can go in a "vars" block here.
}
